rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper functions - simplified to avoid conflicts
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }
    
    function getRole() {
      return exists(/databases/$(database)/documents/USERS/$(request.auth.uid)) ?
        get(/databases/$(database)/documents/USERS/$(request.auth.uid)).data.role : 'user';
    }
    
    function isAdmin() {
      return isAuthenticated() && (getRole() == 'super_admin' || getRole() == 'manager');
    }
    
    function isSuperAdmin() {
      return isAuthenticated() && getRole() == 'super_admin';
    }
    
    // ========== PRIORITY RULES - These take precedence ==========
    
    // General Entries collection - MUST BE EXPLICIT
    match /generalEntries/{entryId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      allow update: if false;
      allow delete: if request.auth != null;
    }
    
    // Vouchers collection - MUST BE EXPLICIT
    match /vouchers/{voucherId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      allow update: if request.auth != null;
      allow delete: if request.auth != null;
    }
    
    // Chart of Accounts collection - MUST BE EXPLICIT
    match /chartOfAccounts/{accountId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      allow update: if request.auth != null;
      allow delete: if request.auth != null;
    }
    
    // Cashflow collection for navbar stats
    match /cashflow/{transactionId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      allow update: if request.auth != null;
      allow delete: if request.auth != null;
    }
    
    // ========== OTHER COLLECTIONS ==========
    
    // Users collections
    match /users/{userId} {
      allow read: if request.auth != null;
      allow write: if isOwner(userId) || isAdmin();
    }
    
    match /USERS/{userId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      allow update: if request.auth != null;
      allow delete: if isSuperAdmin();
    }
    
    // Collections needed for system functionality
    match /categories/{categoryId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      allow update: if request.auth != null;
      allow delete: if request.auth != null;
    }
    
    match /units/{unitId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      allow update: if request.auth != null;
      allow delete: if request.auth != null;
    }
    
    match /settings/{document} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }
    
    match /products/{productId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      allow update: if request.auth != null;
      allow delete: if request.auth != null;
    }
    
    match /sales/{saleId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      allow update: if request.auth != null;
      allow delete: if request.auth != null;
    }
    
    match /purchases/{purchaseId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      allow update: if request.auth != null;
      allow delete: if request.auth != null;
    }
    
    match /parties/{partyId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      allow update: if request.auth != null;
      allow delete: if request.auth != null;
    }
    
    match /inventory/{movementId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      allow update: if request.auth != null;
      allow delete: if false;
    }
    
    match /warehouses/{warehouseId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      allow update: if request.auth != null;
      allow delete: if request.auth != null;
    }
    
    match /currencies/{currencyId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      allow update: if request.auth != null;
      allow delete: if request.auth != null;
    }
    
    match /costCenters/{centerId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      allow update: if request.auth != null;
      allow delete: if request.auth != null;
    }
    
    match /salesReps/{repId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      allow update: if request.auth != null;
      allow delete: if request.auth != null;
    }
    
    match /accounts/{accountId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }
    
    match /journal_entries/{entryId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      allow update: if request.auth != null;
      allow delete: if false;
    }
    
    match /notifications/{notificationId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      allow update: if request.auth != null;
      allow delete: if request.auth != null;
    }
    
    // ========== FALLBACK RULE - MUST BE LAST ==========
    match /{document=**} {
      allow read, write: if request.auth != null;
    }
  }
}